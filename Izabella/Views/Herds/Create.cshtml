@model Herd

@{
    ViewData["Title"] = "Create";
}

<h1>Új Tenyészet felvitele</h1>

<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="Name" class="control-label"></label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="HerdCode" class="control-label"></label>
                <input asp-for="HerdCode" class="form-control" />
                <span asp-validation-for="HerdCode" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="CompanyId" class="control-label"></label>
                <select asp-for="CompanyId" class ="form-control" asp-items="ViewBag.CompanyId"></select>
            </div>
            <div class="form-group">
                <label asp-for="DefaultPrefix" class="control-label"></label>
                <input asp-for="DefaultPrefix" class="form-control" />
                <span asp-validation-for="DefaultPrefix" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="EnarPrefix" class="control-label"></label>
                <input asp-for="EnarPrefix" class="form-control" />
                <span asp-validation-for="EnarPrefix" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Létrehozás" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Vissza a Tenyészetek listához</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
