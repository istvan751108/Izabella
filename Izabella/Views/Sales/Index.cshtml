@model IEnumerable<Izabella.Models.SaleTransaction>

@{
    ViewData["Title"] = "Értékesítési napló";
}

<div class="container-fluid mt-4">
    <div class="card shadow-sm">
        <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center py-3">
            <h5 class="mb-0"><i class="bi bi-journal-check me-2"></i>Értékesítési napló</h5>
            <a asp-controller="Cattles" asp-action="Index" class="btn btn-sm btn-outline-light">
                <i class="bi bi-arrow-left"></i> Vissza az állományhoz
            </a>
        </div>
        <div class="d-flex justify-content-between align-items-center mb-3">
            <div>
                <a asp-action="DownloadPendingEnarXml" class="btn btn-primary shadow-sm">
                    <i class="bi bi-file-earmark-arrow-down"></i> ENAR Bejelentő (XML) Letöltése
                </a>
            </div>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Dátum</th>
                            <th>Fülszám</th>
                            <th>Vevő</th>
                            <th>Bizonylat</th>
                            <th class="text-end">Bruttó (kg)</th>
                            <th class="text-end">Levonás</th>
                            <th class="text-end">Nettó (kg)</th>
                            <th class="text-end">Egységár (Ft/kg)</th>
                            <th class="text-end">Összesen (Nettó)</th>
                            <th class="text-center">Műveletek</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            // Megkülönböztetjük az elhullást (0 Ft-os ár)
                            var rowClass = item.UnitPrice == 0 ? "table-danger" : "";
                            var typeLabel = item.UnitPrice == 0 ? "ELHULLÁS" : "ELADÁS";

                            <tr class="@rowClass">
                                <td><span class="badge bg-secondary">@item.SaleDate.ToString("yyyy.MM.dd")</span></td>
                                <td>
                                    <div class="fw-bold text-primary">@item.Cattle.EarTag</div>
                                    <span class="badge bg-light text-dark border small">@typeLabel</span>
                                </td>
                                <td>@item.Customer.Name</td>
                                <td><small class="fw-bold">@item.ReceiptNumber</small></td>
                                @if (item.UnitPrice > 0)
                                {
                                    <td class="text-end">@item.GrossWeight.ToString("N1")</td>
                                    <td class="text-end text-danger small">@item.DeductionPercentage%</td>
                                    <td class="text-end fw-bold">@item.NetWeight.ToString("N1")</td>
                                    <td class="text-end">@item.UnitPrice.ToString("N0")</td>
                                    <td class="text-end fw-bold text-success">@item.TotalNetPrice.ToString("N0") Ft</td>
                                }
                                else
                                {
                                    <td colspan="5" class="text-center text-muted italic">Elhullás/Vágás kivezetve</td>
                                }
                                <td class="text-center">
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
        <div class="card-footer bg-white text-muted small">
            Összesen @Model.Count() tétel az időszakban.
        </div>
    </div>
</div>