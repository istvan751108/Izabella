@using Izabella.Models
@model IEnumerable<Izabella.Models.SaleTransaction>

@{
    ViewData["Title"] = "Havi Statisztikai Napló";

    // 1. Elhullások (ahol nincs egységár)
    var elhullasok = Model.Where(x => x.UnitPrice == 0).ToList();
    
    // 2. Tulajdonosváltások (Enum alapján - Ügyelj a pontos OwnershipChange névre!)
    var tulajdonosValtasok = Model.Where(x => x.Type == SaleType.OwnershipChange).ToList();
    
    // 3. Normál értékesítések (ami nem az előző kettő)
    // Itt 'simaErtekesitesek' a neve!
    var simaErtekesitesek = Model.Where(x => x.UnitPrice > 0 && x.Type != SaleType.OwnershipChange).ToList();

    var newborns = ViewBag.Newborns as List<Cattle> ?? new List<Cattle>();
    var mothers = ViewBag.Mothers as List<Cattle> ?? new List<Cattle>();
}

<div class="container-fluid mt-4">
    @* FEJLÉC - Letisztítva, csak a szűréssel *@
    <div class="d-flex justify-content-between align-items-center mb-4 p-3 bg-white rounded shadow-sm border">
        <div>
            <h2 class="mb-0 text-dark"><i class="bi bi-calendar3 text-primary"></i> Statisztikai Napló + Enar ügyintézés</h2>
            <span class="text-muted">@ViewBag.Year. @ViewBag.Month. hónap</span>
        </div>
        
        <form asp-action="MonthlyReport" method="get" class="d-flex gap-2">
            <input type="number" name="year" value="@ViewBag.Year" class="form-control" style="width: 100px;" />
            <select name="month" class="form-select" style="width: 150px;">
                @for (int i = 1; i <= 12; i++)
                {
                    <option value="@i" selected="@(i == (int)ViewBag.Month)">@i. hónap</option>
                }
            </select>
            <button type="submit" class="btn btn-secondary">Szűrés</button>
        </form>
    </div>

    @* --- ELLÉSEK SZEKCIÓ (Bejelentő gombbal és összefoglalóval) --- *@
    <div class="card shadow-sm mb-5 border-primary">
        <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center py-3">
            <h5 class="mb-0"><i class="bi bi-gender-ambiguous"></i> Ellések és Szaporulat</h5>
            @* Ez a gomb váltja ki a régi menüpontot *@
            <a asp-action="EnarReporting" asp-controller="Cattle" class="btn btn-light btn-sm fw-bold">
                <i class="bi bi-megaphone"></i> Új ellések bejelentése
            </a>
        </div>
        <div class="card-body">
            @if (!newborns.Any())
            {
                <p class="text-muted text-center my-3">Ebben a hónapban nem történt ellés.</p>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-sm table-hover align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>Dátum</th>
                                <th>Borjú Fülszám</th>
                                <th>Anya ENAR</th>
                                <th>Anya kora</th>
                                <th>Súly</th>
                                <th>Iker?</th>
                                <th>Élve?</th>
                                <th>Ivar</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var calf in newborns.OrderBy(n => n.BirthDate))
                            {
                                var anya = mothers.FirstOrDefault(m => m.EnarNumber == calf.MotherEnar);
                                <tr class="@(!calf.IsAlive ? "table-danger-subtle text-danger" : "")">
                                    <td>@calf.BirthDate.ToString("yyyy.MM.dd")</td>
                                    <td class="fw-bold">@(calf.IsAlive? calf.EarTag: "HALVA SZÜLETETT")</td>
                                    <td>@calf.MotherEnar</td>
                                    <td>@(anya?.DamAgeAtCalving ?? "Ismeretlen")</td>
                                    <td>@calf.BirthWeight kg</td>
                                    <td>@(calf.IsTwin ? "Igen" : "Nem")</td>
                                    <td>@(calf.IsAlive ? "Igen" : "Nem")</td>
                                    <td>@(calf.Gender == Gender.Bika ? "♂ Bika" : "♀ Üsző")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                @* ÖSSZEFOGLALÓ STATISZTIKA (Visszahozva) *@
                <div class="row g-3 mt-2">
                    @{
                        var birthsByMother = newborns.GroupBy(n => n.MotherEnar).ToList();
                        var tehenEllesCount = birthsByMother.Count(g => mothers.FirstOrDefault(m => m.EnarNumber == g.Key)?.DamAgeAtCalving == "Tehén");
                        var uszoEllesCount = birthsByMother.Count - tehenEllesCount;
                        var hullaEllesCount = birthsByMother.Count(g => g.All(b => !b.IsAlive));
                    }
                    <div class="col-md-3">
                        <div class="p-2 border rounded bg-light text-center">
                            <small class="text-muted d-block">Összes ellés</small>
                            <span class="h5 mb-0">@birthsByMother.Count</span>
                            <div class="small">Tehén: @tehenEllesCount | Üsző: @uszoEllesCount</div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="p-2 border rounded bg-light text-center">
                            <small class="text-muted d-block">Ikerellések</small>
                            <span class="h5 mb-0 text-info">@birthsByMother.Count(g => g.Count() > 1)</span>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="p-2 border rounded bg-light text-center border-danger">
                            <small class="text-danger d-block">Hullaellés</small>
                            <span class="h5 mb-0 text-danger">@hullaEllesCount</span>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="p-2 border rounded bg-success-subtle text-center border-success">
                            <small class="text-success d-block">Élő szaporulat</small>
                            <span class="h5 mb-0 text-success">@newborns.Count(n => n.IsAlive)</span>
                            <div class="small text-success">@newborns.Count(n => n.IsAlive && n.Gender == Gender.Bika) B | @newborns.Count(n => n.IsAlive && n.Gender == Gender.Üsző) Ü</div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
    @* --- 3. SZEKCIÓ: ÁTHELYEZÉSEK (Áttekintő) --- *@
    <div class="card shadow-sm mb-5 border-warning">
            <div class="card-header bg-warning text-dark d-flex justify-content-between align-items-center py-3">
                <h5 class="mb-0"><i class="bi bi-truck"></i> Havi áthelyezések (ENAR 5147)</h5>
                <a asp-action="PendingMovements" asp-controller="Cattles" class="btn btn-dark btn-sm fw-bold">
                    <i class="bi bi-pencil-square"></i> Áthelyezések kezelése
                </a>
            </div>
            <div class="card-body">
                @if (ViewBag.MonthlyMovements != null && ((List<AnimalHistory>)ViewBag.MonthlyMovements).Any())
                {
                    <div class="table-responsive">
                        <table class="table table-sm table-hover align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th>Dátum</th>
                                    <th>Fülszám</th>
                                    <th>Honnan</th>
                                    <th>Hová</th>
                                    <th class="text-center">Státusz</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var move in (List<AnimalHistory>)ViewBag.MonthlyMovements)
                                {
                                    var codes = ViewBag.HerdCodes as Dictionary<int, string>;
                                    <tr>
                                        <td>@move.EventDate.ToString("yyyy.MM.dd")</td>
                                        <td class="fw-bold">@move.Cattle?.EarTag</td>
                                        <td><small>@(move.OldHerdId.HasValue && codes.ContainsKey(move.OldHerdId.Value) ? codes[move.OldHerdId.Value] : "---")</small></td>
                                        <td><span class="badge bg-light text-dark border">@(move.NewHerdId.HasValue && codes.ContainsKey(move.NewHerdId.Value) ? codes[move.NewHerdId.Value] : "---")</span></td>
                                        <td class="text-center">
                                            @if (move.IsEnarReported)
                                            {
                                                <span class="badge bg-success"><i class="bi bi-check-circle"></i> Beküldve</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-danger"><i class="bi bi-exclamation-triangle"></i> Bejelentésre vár</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <p class="text-muted text-center my-3">Ebben a hónapban nem történt belső áthelyezés.</p>
                }
            </div>
        </div>
    @* --- 2. SZEKCIÓ: KIKERÜLÉSEK (Közös keretben az ENAR kijelentéshez) --- *@
    <div class="card shadow border-0 bg-light p-4 mb-5">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h4 class="mb-0 text-dark"><i class="bi bi-box-arrow-right"></i> Kikerülések kezelése (ENAR 5136)</h4>
            <div class="text-muted small">Válassza ki a bejelenteni kívánt tételeket a listákból!</div>
        </div>

        <form id="enarForm" asp-action="GenerateEnar5136Package" asp-controller="Sales" method="post">
            @* ELHULLÁSOK AL-KÁRTYA *@
            <div class="card shadow-sm mb-4 border-danger">
                <div class="card-header bg-danger text-white d-flex justify-content-between align-items-center">
                    <h6 class="mb-0">Elhullások kijelölése</h6>
                    <div class="form-check">
                        <input class="form-check-input select-all-section" type="checkbox" data-target="death-check" id="selectAllDeaths">
                        <label class="form-check-label small" for="selectAllDeaths">Mind</label>
                    </div>
                </div>
                <div class="card-body p-0">
                <table class="table table-hover mb-0 align-middle">
                    <thead class="table-light">
                        <tr>
                            <th style="width:40px;" class="ps-3"></th>
                            <th>Dátum</th>
                            <th>Fülszám</th>
                            <th>Korcsoport</th>
                            <th>Tenyészet</th>
                            <th class="text-end">Súly (kg)</th>
                            <th class="text-center">Státusz</th>
                            <th class="text-end pe-3">Művelet</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in elhullasok)
                        {
                            <tr class="@(item.IsReported ? "table-light" : "")">
                                <td class="ps-3">
                                    @if (!item.IsReported)
                                    {
                                        <input type="checkbox" name="selectedIds" value="@item.Id" class="form-check-input enar-check death-check border-danger">
                                    }
                                    else
                                    {
                                        <i class="bi bi-cloud-check-fill text-success fs-5"></i>
                                    }
                                </td>
                                <td>@item.SaleDate.ToString("yyyy.MM.dd")</td>
                                <td>
                                    <a asp-controller="Cattles" asp-action="Edit" asp-route-id="@item.CattleId"
                                           asp-route-returnUrl="@Context.Request.Path@Context.Request.QueryString"
                                           class="fw-bold text-decoration-none text-danger">
                                        @item.Cattle?.EarTag
                                    </a>
                                </td>
                                <td>@item.Cattle?.AgeGroup</td>
                                <td><small class="text-muted">@item.Cattle?.CurrentHerd?.HerdCode</small></td>
                                <td class="text-end">@item.GrossWeight.ToString("N1")</td>
                                <td class="text-center">
                                    @if (item.IsReported)
                                    {
                                        <span class="badge bg-success-subtle text-success border border-success">Beküldve</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning-subtle text-warning border border-warning">Várakozik</span>
                                    }
                                </td>
                                <td class="text-end pe-3">
                                    @if (item.IsReported)
                                    {
                                        <button type="button" onclick="undoReport(@item.Id)" class="btn btn-sm btn-outline-warning" title="Visszavonás (újra beküldhető lesz)">
                                            <i class="bi bi-arrow-counterclockwise"></i> Visszavon
                                        </button>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

            @* TULAJDONOSVÁLTÁS AL-KÁRTYA *@
            <div class="card shadow-sm mb-4 border-info">
                <div class="card-header bg-info text-white d-flex justify-content-between align-items-center">
                    <h6 class="mb-0"><i class="bi bi-person-bounding-box"></i> Tulajdonosváltás kijelölése</h6>
                    <div class="form-check">
                        <input class="form-check-input select-all-section" type="checkbox" data-target="owner-check" id="selectAllOwners">
                        <label class="form-check-label small" for="selectAllOwners">Mind</label>
                    </div>
                </div>
                <div class="card-body p-0">
                    <table class="table table-sm mb-0">
                        @foreach (var item in tulajdonosValtasok)
                        {
                            <tr class="@(item.IsReported ? "table-light text-muted" : "")">
                                <td style="width: 40px;" class="ps-3">
                                    @if (!item.IsReported)
                                    {
                                        <input type="checkbox" name="selectedCattleIds" value="@item.CattleId" class="form-check-input enar-check owner-check">
                                    }
                                    else
                                    {
                                        <i class="bi bi-cloud-check-fill text-info fs-5"></i>
                                    }
                                </td>
                                <td>
                                    <span class="@(item.IsReported ? "" : "fw-bold")">@item.Cattle?.EarTag</span>
                                </td>
                                <td><small>@item.Cattle?.EnarNumber</small></td>
                                <td>
                                    @if (item.IsReported)
                                    {
                                        <span class="badge bg-info-subtle text-info border border-info">Átvezetve ide: @item.Customer?.Name</span>
                                    }
                                    else
                                    {
                                        <span>Új hely: <strong>@item.Customer?.Name</strong></span>
                                    }
                                </td>
                                <td class="text-end pe-3">
                                    @if (item.IsReported)
                                    {
                                        <button type="button" onclick="undoReport(@item.Id)" class="btn btn-sm btn-outline-info">
                                            <i class="bi bi-arrow-counterclockwise"></i> XML Újra
                                        </button>
                                    }
                                </td>
                            </tr>
                        }
                    </table>
                </div>
            </div>
            @* ÉRTÉKESÍTÉSEK AL-KÁRTYA *@
            <div class="card shadow-sm mb-4 border-success">
                <div class="card-header bg-success text-white d-flex justify-content-between align-items-center">
                    <h6 class="mb-0">Értékesítések kijelölése</h6>
                    <div class="form-check">
                        <input class="form-check-input select-all-section" type="checkbox" data-target="sale-check" id="selectAllSales">
                        <label class="form-check-label small" for="selectAllSales">Mind</label>
                    </div>
                </div>
                <div class="card-body p-0">
                <table class="table table-hover mb-0 align-middle">
                    <thead class="table-light">
                        <tr>
                            <th style="width:40px;" class="ps-3"></th>
                            <th>Dátum</th>
                            <th>Fülszám</th>
                            <th>Vevő</th>
                            <th>Típus</th>
                            <th class="text-end">Végösszeg</th>
                            <th class="text-center">Státusz</th>
                            <th class="text-end pe-3">Művelet</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in simaErtekesitesek)
                        {
                            <tr class="@(item.IsReported ? "table-light" : "")">
                                <td class="ps-3">
                                    @if (!item.IsReported)
                                    {
                                        <input type="checkbox" name="selectedIds" value="@item.Id" class="form-check-input enar-check sale-check border-success">
                                    }
                                    else
                                    {
                                        <i class="bi bi-cloud-check-fill text-success fs-5"></i>
                                    }
                                </td>
                                <td>@item.SaleDate.ToString("yyyy.MM.dd")</td>
                                <td>
                                    <a asp-controller="Cattles" asp-action="Edit" asp-route-id="@item.CattleId"
                                           asp-route-returnUrl="@Context.Request.Path@Context.Request.QueryString"
                                           class="fw-bold text-decoration-none text-success">
                                        @item.Cattle?.EarTag
                                    </a>
                                </td>
                                <td>@item.Customer?.Name</td>
                                    <td>
                                        <span class="badge bg-light text-dark border small">
                                            @{
                                                var typeName = item.Type switch
                                                {
                                                    SaleType.Slaughter => "Vágás",
                                                    SaleType.FurtherBreeding => "Továbbtartás",
                                                    SaleType.Export => "Export",
                                                    SaleType.OwnershipChange => "Tulajdonosváltás",
                                                    _ => item.Type.ToString()
                                                };
                                            }
                                            @typeName
                                        </span>
                                    </td>
                                <td class="text-end fw-bold">@item.TotalNetPrice.ToString("N0") Ft</td>
                                <td class="text-center">
                                    @if (item.IsReported)
                                    {
                                        <span class="badge bg-success-subtle text-success border border-success">Beküldve</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning-subtle text-warning border border-warning">Várakozik</span>
                                    }
                                </td>
                                <td class="text-end pe-3">
                                    @if (item.IsReported)
                                    {
                                        <button type="button" onclick="undoReport(@item.Id)" class="btn btn-sm btn-outline-warning">
                                            <i class="bi bi-arrow-counterclockwise"></i> Visszavon
                                        </button>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
            @* A GOMB MOST MÁR ITT VAN ALUL, A KIJELÖLÉSEK UTÁN *@
            <div class="d-grid gap-2 d-md-flex justify-content-md-end mt-4">
                <div id="checkCounter" class="me-3 align-self-center text-muted fw-bold" style="display:none;">
                    <span id="selectedCount">0</span> tétel kijelölve
                </div>
                <button type="button" onclick="submitEnarPackage()" class="btn btn-success btn-lg shadow" id="btnMainExport" disabled>
                    <i class="bi bi-file-zip-fill"></i> Kijelöltek ENAR kijelentése (ZIP generálása)
                </button>
            </div>
    </form>
    </div>
    <iframe name="download_frame" id="download_frame" style="display:none;"></iframe>
</div>
@* Rejtett form a visszavonáshoz (Sale visszavonás) *@
<form id="undoSaleForm" asp-action="UndoReport" asp-controller="Sales" method="post" style="display:none;">
    @Html.AntiForgeryToken()
    <input type="hidden" name="id" id="undoSaleId" />
</form>

<div class="modal fade" id="vetModal" tabindex="-1" aria-labelledby="vetModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-info text-white">
                <h5 class="modal-title" id="vetModalLabel"><i class="bi bi-hospital"></i> Állatorvosi adatok az 5135-öshöz</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label class="form-label text-dark fw-bold">Cél tenyészet</label>
                    <select class="form-select" id="targetHerdId" name="targetHerdId">
                        @if (ViewBag.Herds != null)
                        {
                            foreach (var herd in (IEnumerable<Izabella.Models.Herd>)ViewBag.Herds)
                            {
                                <option value="@herd.HerdCode">@herd.Name (@herd.HerdCode)</option>
                            }
                        }
                        else
                        {
                            <option value="">Nincsenek betöltött tenyészetek!</option>
                        }
                    </select>
                </div>
                <div class="mb-3">
                    <label for="certNumber" class="form-label text-dark fw-bold">Bizonyítvány sorszáma</label>
                    <input type="text" class="form-control" id="certNumber" value="BE">
                </div>
                <div class="mb-3">
                    <label for="stampNumber" class="form-label text-dark fw-bold">Kamarai bélyegző száma</label>
                    <input type="text" class="form-control" id="stampNumber" value="0134">
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Mégse</button>
                <button type="button" onclick="confirmSubmit()" class="btn btn-info text-white">XML-ek generálása</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('.select-all-section').click(function () {
                var targetClass = $(this).data('target');
                $('.' + targetClass).prop('checked', this.checked);
                updateMainButton();
            });

            $(document).on('change', '.enar-check', function() {
                updateMainButton();
            });

            function updateMainButton() {
            // Csak a kikerülések (elhullás, eladás, tulajdonosváltás) számlálása
            var checkedCount = $('.death-check:checked, .sale-check:checked, .owner-check:checked').length;

            $('#btnMainExport').prop('disabled', checkedCount === 0);

            if(checkedCount > 0) {
                $('#selectedCount').text(checkedCount);
                $('#checkCounter').fadeIn();
                $('#btnMainExport').html('<i class="bi bi-check-all"></i> ' + checkedCount + ' tétel beküldése (ZIP)');
            } else {
                $('#checkCounter').hide();
                $('#btnMainExport').html('<i class="bi bi-file-zip-fill"></i> Kijelöltek ENAR kijelentése');
            }
        }
        });

        function submitEnarPackage() {
            var ownerChangeCount = $('.owner-check:checked').length;
            var normalSaleCount = $('.sale-check:checked, .death-check:checked').length;

            if (ownerChangeCount > 0) {
                // Ha van tulajdonosváltás, először a modalt mutatjuk
                var myModal = new bootstrap.Modal(document.getElementById('vetModal'));
                myModal.show();
            } else if (normalSaleCount > 0) {
                if (confirm('A kijelölt tételekről ENAR 5136-os csomag készül. Folytatja?')) {
                    executeSubmit(false); // false = sima kikerülés
                }
            }
        }

        function confirmSubmit() {
            var cert = $('#certNumber').val();
            if (cert.length < 5) {
                alert('Kérlek add meg a bizonylat sorszámát!');
                return;
            }
            executeSubmit(true); // true = tulajdonosváltás
        }

         function executeSubmit(isOwnerChange) {
            var form = $('#enarForm');
    
            // TÖRLÉS: Ne legyen target, se iframe!
            form.removeAttr('target');

            if (isOwnerChange) {
                form.attr('action', '/Sales/ProcessOwnerChange');
                form.find('.temp-hidden').remove();

                $('<input>').attr({type: 'hidden', name: 'targetHerdCode', value: $('#targetHerdId').val(), class: 'temp-hidden'}).appendTo(form);
                $('<input>').attr({type: 'hidden', name: 'targetOwnerName', value: $('#targetHerdId option:selected').text(), class: 'temp-hidden'}).appendTo(form);
                $('<input>').attr({type: 'hidden', name: 'certNumber', value: $('#certNumber').val(), class: 'temp-hidden'}).appendTo(form);
                $('<input>').attr({type: 'hidden', name: 'stampNumber', value: $('#stampNumber').val(), class: 'temp-hidden'}).appendTo(form);
                $('<input>').attr({type: 'hidden', name: 'moveDate', value: new Date().toISOString().split('T')[0], class: 'temp-hidden'}).appendTo(form);
        
                var modalInstance = bootstrap.Modal.getInstance(document.getElementById('vetModal'));
                if(modalInstance) modalInstance.hide();
            } else {
                // SIMA 5136 (Elhullás/Eladás)
                form.attr('action', '/Sales/GenerateEnar5136Package');
            }

            // Beküldés a főablakban
            form.submit();

            // Egyetlen figyelmeztetés
            alert("A kért dokumentumok generálása elindult.");
    
            // Csak 5 másodperc múlva frissítünk, hogy a böngészőnek legyen ideje feldolgozni a letöltést
            setTimeout(function() {
                if(confirm("Szeretné frissíteni az oldalt a státuszok ellenőrzéséhez?")) {
                    location.reload();
                }
            }, 5000);
        }

        // Segédfüggvény a tiszta kódhoz
        function addHiddenField(form, name, value) {
            var input = document.createElement('input');
            input.type = 'hidden';
            input.name = name;
            input.value = value;
            form.appendChild(input);
        }
        function undoReport(transactionId) {
            if (confirm('Biztosan visszavonja az ENAR jelentés státuszát? Ezzel a tétel újra beküldhetővé válik.')) {
                // Megkeressük a rejtett formot és a beviteli mezőjét
                $('#undoSaleId').val(transactionId);
                // Elküldjük a formot
                $('#undoSaleForm').submit();
            }
        }
    </script>
}