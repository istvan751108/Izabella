@using Izabella.Models @* Fontos, hogy az Enumok elérhetőek legyenek *@
@model IEnumerable<Izabella.Models.SaleTransaction>

@{
    ViewData["Title"] = "Havi Statisztikai Napló";
    var elhullasok = Model.Where(x => x.UnitPrice == 0).ToList();
    var ertekesitesek = Model.Where(x => x.UnitPrice > 0).ToList();
}

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="bi bi-graph-up"></i> Statisztikai Napló - @ViewBag.Year. @ViewBag.Month. hónap</h2>
        <form asp-action="MonthlyReport" method="get" class="d-flex gap-2">
            <input type="number" name="year" value="@ViewBag.Year" class="form-control" style="width: 100px;" />
            <select name="month" class="form-select" style="width: 150px;">
                @for (int i = 1; i <= 12; i++)
                {
                    if (i == (int)ViewBag.Month)
                    {
                        <option value="@i" selected>@i. hónap</option>
                    }
                    else
                    {
                        <option value="@i">@i. hónap</option>
                    }
                }
            </select>
            <button type="submit" class="btn btn-primary">Szűrés</button>
        </form>
    </div>

    @* --- ELHULLÁSOK --- *@
    <div class="card shadow-sm mb-5 border-danger">
        <div class="card-header bg-danger text-white"><h5>Elhullások</h5></div>
        <div class="card-body p-0">
            <table class="table table-sm table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Dátum</th>
                        <th>Fülszám</th>
                        <th>Korcsoport</th>
                        <th>Nem</th>
                        <th>Tenyészet</th>
                        <th class="text-end">Súly (kg)</th>
                        <th>Ok / Bizonylat</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in elhullasok)
                    {
                        <tr>
                            <td>@item.SaleDate.ToString("yyyy.MM.dd")</td>
                            <td>@item.Cattle?.EarTag</td>
                            <td>@item.Cattle?.AgeGroup</td>
                            <td>@item.Cattle?.Gender</td>
                            <td>@item.Cattle?.CurrentHerd?.HerdCode</td>
                            <td class="text-end">@item.GrossWeight.ToString("N1")</td>
                            <td>@item.ReceiptNumber</td>
                        </tr>
                    }
                </tbody>
                <tfoot class="table-secondary fw-bold">
                    @foreach (var group in elhullasok.GroupBy(x => x.Cattle?.AgeGroup ?? "Ismeretlen"))
                    {
                        <tr>
                            <td colspan="4">Összesítés: @group.Key</td>
                            <td class="text-end">@group.Count() db</td>
                            <td class="text-end">@group.Sum(x => (double)x.GrossWeight).ToString("N1") kg</td>
                            <td></td>
                        </tr>
                    }
                </tfoot>
            </table>
        </div>
    </div>

    @* --- ÉRTÉKESÍTÉSEK --- *@
    <div class="card shadow-sm mb-4 border-success">
        <div class="card-header bg-success text-white"><h5>Értékesítések</h5></div>
        <div class="card-body p-0">
            <table class="table table-sm table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Dátum</th>
                        <th>Fülszám</th>
                        <th>Korcsoport</th>
                        <th>Nem</th>
                        <th>Vevő</th>
                        <th>Típus</th>
                        <th>Tenyészet</th>
                        <th class="text-end">Súly (kg)</th>
                        <th class="text-end">Végösszeg</th>
                        <th>Bizonylat</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in ertekesitesek)
                    {
                        <tr>
                            <td>@item.SaleDate.ToString("yyyy.MM.dd")</td>
                            <td class="fw-bold">@item.Cattle?.EarTag</td>
                            <td>@item.Cattle?.AgeGroup</td>
                            <td>@item.Cattle?.Gender</td>
                            <td>@item.Customer?.Name</td>
                            <td>
                                <span class="badge bg-light text-dark border">
                                    @{
                                        switch (item.Type)
                                        {
                                            case SaleType.Slaughter:
                                                @:Vágás
                                                break;
                                            case SaleType.FurtherBreeding:

                                                @:Továbbtartás
                                                break;
                                            case SaleType.Export:

                                                @:Export
                                                break;
                                            case SaleType.OwnershipChange:

                                                @:Tulajdonosváltás
                                                break;
                                            default:

                                                @item.Type.ToString()
                                                break;
                                        }
                                    }
                                </span>
                            </td>
                            <td>@item.Cattle?.CurrentHerd?.HerdCode</td>
                            <td class="text-end">@item.NetWeight.ToString("N1")</td>
                            <td class="text-end fw-bold">@item.TotalNetPrice.ToString("N0") Ft</td>
                            <td>@item.ReceiptNumber</td>
                        </tr>
                    }
                </tbody>
                <tfoot class="table-secondary fw-bold">
                    @foreach (var group in ertekesitesek.GroupBy(x => x.Cattle?.AgeGroup ?? "Ismeretlen"))
                    {
                        <tr>
                            <td colspan="5">Összesítés: @group.Key</td>
                            <td class="text-center">@group.Count() db</td>
                            <td></td>
                            <td class="text-end">@group.Sum(x => (double)x.NetWeight).ToString("N1") kg</td>
                            <td class="text-end text-success">@group.Sum(x => x.TotalNetPrice).ToString("N0") Ft</td>
                            <td></td>
                        </tr>
                    }
                </tfoot>
            </table>
        </div>
    </div>
</div>
@using Izabella.Models
@{
    var newborns = ViewBag.Newborns as List<Cattle> ?? new List<Cattle>();
    var mothers = ViewBag.Mothers as List<Cattle> ?? new List<Cattle>();

    // --- LOGIKA AZ ÖSSZESÍTŐHÖZ ---
    var birthsByMother = newborns.GroupBy(n => n.MotherEnar).ToList();
    
    // Hullaellés: Az anyának csak halva született borja van az adott ellésnél
    int hullaEllesTehen = 0;
    int hullaEllesUszo = 0;
    
    foreach (var group in birthsByMother)
    {
        var anya = mothers.FirstOrDefault(m => m.EnarNumber == group.Key);
        bool mindenHalott = group.All(b => b.IsAlive == false);
        if (mindenHalott)
        {
            if (anya?.DamAgeAtCalving == "Tehén") hullaEllesTehen++;
            else hullaEllesUszo++;
        }
    }
}

<div class="card shadow-sm mb-4 border-primary">
    <div class="card-header bg-primary text-white"><h5>Ellések</h5></div>
    <div class="card-body p-0">
        <table class="table table-sm table-hover mb-0 text-center">
            <thead class="table-light">
                <tr>
                    <th>Dátum</th>
                    <th>Borjú Fülszám</th>
                    <th>Anya ENAR</th>
                    <th>Anya kora</th>
                    <th>Súly</th>
                    <th>Iker?</th>
                    <th>Élve?</th>
                    <th>Ivar</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var calf in newborns.OrderBy(n => n.BirthDate))
                {
                    var anya = mothers.FirstOrDefault(m => m.EnarNumber == calf.MotherEnar);
                    <tr class="@(!calf.IsAlive ? "table-secondary text-muted" : "")">
                        <td>@calf.BirthDate.ToString("yyyy.MM.dd")</td>
                        <td>@(calf.IsAlive? calf.EarTag: "HALVA")</td>
                        <td>@calf.MotherEnar</td>
                        <td>@(anya?.DamAgeAtCalving ?? "Ismeretlen")</td>
                        <td>@calf.BirthWeight kg</td>
                        <td>@(calf.IsTwin ? "Igen" : "Nem")</td>
                        <td>@(calf.IsAlive ? "Igen" : "NEM")</td>
                        <td>@calf.Gender</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    <div class="card-footer bg-white">
        <div class="row text-center fw-bold">
            @{
                // Előre kiszámoljuk a pontos számokat a szűrt 'newborns' listából
                var szurtBorjak = newborns.ToList();
                var szurtEllesek = szurtBorjak.GroupBy(n => n.MotherEnar).ToList();
            
                int osszesBorju = szurtBorjak.Count;
                int eloBika = szurtBorjak.Count(n => n.IsAlive && n.Gender == Gender.Bika);
                int eloUszo = szurtBorjak.Count(n => n.IsAlive && n.Gender == Gender.Üsző);
                int halvaSzuletett = szurtBorjak.Count(n => !n.IsAlive);

                // Ikerellések száma (ahol az anyának több borja született aznap)
                int ikerElles = szurtEllesek.Count(g => g.Count() > 1);
            }

            <div class="col-md-3 border-end">
                <p class="text-primary mb-1">ELLÉSEK SZÁMA</p>
                @{
                    var tehenElles = szurtEllesek.Count(g => mothers.FirstOrDefault(m => m.EnarNumber == g.Key)?.DamAgeAtCalving == "Tehén");
                    var uszoElles = szurtEllesek.Count - tehenElles;
                }
                Tehén: @tehenElles <br />
                V. Üsző: @uszoElles <br />
                Összes: @szurtEllesek.Count
            </div>

            <div class="col-md-3 border-end">
                <p class="text-info mb-1">IKERELLÉSEK</p>
                @{
                    var ikerTehen = szurtEllesek.Where(g => g.Count() > 1)
                                    .Count(g => mothers.FirstOrDefault(m => m.EnarNumber == g.Key)?.DamAgeAtCalving == "Tehén");
                }
                Tehén: @ikerTehen <br />
                V. Üsző: @(ikerElles - ikerTehen) <br />
                Összes: @ikerElles
            </div>

            <div class="col-md-3 border-end text-danger">
                <p class="mb-1">HULLAELLÉSEK</p>
                Tehén: @hullaEllesTehen <br />
                V. Üsző: @hullaEllesUszo <br />
                Összes: @(hullaEllesTehen + hullaEllesUszo)
            </div>

            <div class="col-md-3 text-success">
                <p class="mb-1">SZAPORULAT (Élő)</p>
                Bika: @eloBika <br />
                Üsző: @eloUszo <br />
                <span class="text-dark">Összes élő szaporulat: @(eloBika + eloUszo)</span>
            </div>
        </div>
    </div>
</div>