@using Izabella.Models
@model IEnumerable<Izabella.Models.SaleTransaction>

@{
    ViewData["Title"] = "Havi Statisztikai Napló";
    var elhullasok = Model.Where(x => x.UnitPrice == 0).ToList();
    var ertekesitesek = Model.Where(x => x.UnitPrice > 0).ToList();
    var newborns = ViewBag.Newborns as List<Cattle> ?? new List<Cattle>();
    var mothers = ViewBag.Mothers as List<Cattle> ?? new List<Cattle>();
}

<div class="container-fluid mt-4">
    @* FEJLÉC - Letisztítva, csak a szűréssel *@
    <div class="d-flex justify-content-between align-items-center mb-4 p-3 bg-white rounded shadow-sm border">
        <div>
            <h2 class="mb-0 text-dark"><i class="bi bi-calendar3 text-primary"></i> Statisztikai Napló + Enar ügyintézés</h2>
            <span class="text-muted">@ViewBag.Year. @ViewBag.Month. hónap</span>
        </div>
        
        <form asp-action="MonthlyReport" method="get" class="d-flex gap-2">
            <input type="number" name="year" value="@ViewBag.Year" class="form-control" style="width: 100px;" />
            <select name="month" class="form-select" style="width: 150px;">
                @for (int i = 1; i <= 12; i++)
                {
                    <option value="@i" selected="@(i == (int)ViewBag.Month)">@i. hónap</option>
                }
            </select>
            <button type="submit" class="btn btn-secondary">Szűrés</button>
        </form>
    </div>

    @* --- ELLÉSEK SZEKCIÓ (Bejelentő gombbal és összefoglalóval) --- *@
    <div class="card shadow-sm mb-5 border-primary">
        <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center py-3">
            <h5 class="mb-0"><i class="bi bi-gender-ambiguous"></i> Ellések és Szaporulat</h5>
            @* Ez a gomb váltja ki a régi menüpontot *@
            <a asp-action="EnarReporting" asp-controller="Cattle" class="btn btn-light btn-sm fw-bold">
                <i class="bi bi-megaphone"></i> Új ellések bejelentése
            </a>
        </div>
        <div class="card-body">
            @if (!newborns.Any())
            {
                <p class="text-muted text-center my-3">Ebben a hónapban nem történt ellés.</p>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-sm table-hover align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>Dátum</th>
                                <th>Borjú Fülszám</th>
                                <th>Anya ENAR</th>
                                <th>Anya kora</th>
                                <th>Súly</th>
                                <th>Iker?</th>
                                <th>Élve?</th>
                                <th>Ivar</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var calf in newborns.OrderBy(n => n.BirthDate))
                            {
                                var anya = mothers.FirstOrDefault(m => m.EnarNumber == calf.MotherEnar);
                                <tr class="@(!calf.IsAlive ? "table-danger-subtle text-danger" : "")">
                                    <td>@calf.BirthDate.ToString("yyyy.MM.dd")</td>
                                    <td class="fw-bold">@(calf.IsAlive? calf.EarTag: "HALVA SZÜLETETT")</td>
                                    <td>@calf.MotherEnar</td>
                                    <td>@(anya?.DamAgeAtCalving ?? "Ismeretlen")</td>
                                    <td>@calf.BirthWeight kg</td>
                                    <td>@(calf.IsTwin ? "Igen" : "Nem")</td>
                                    <td>@(calf.IsAlive ? "Igen" : "Nem")</td>
                                    <td>@(calf.Gender == Gender.Bika ? "♂ Bika" : "♀ Üsző")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                @* ÖSSZEFOGLALÓ STATISZTIKA (Visszahozva) *@
                <div class="row g-3 mt-2">
                    @{
                        var birthsByMother = newborns.GroupBy(n => n.MotherEnar).ToList();
                        var tehenEllesCount = birthsByMother.Count(g => mothers.FirstOrDefault(m => m.EnarNumber == g.Key)?.DamAgeAtCalving == "Tehén");
                        var uszoEllesCount = birthsByMother.Count - tehenEllesCount;
                        var hullaEllesCount = birthsByMother.Count(g => g.All(b => !b.IsAlive));
                    }
                    <div class="col-md-3">
                        <div class="p-2 border rounded bg-light text-center">
                            <small class="text-muted d-block">Összes ellés</small>
                            <span class="h5 mb-0">@birthsByMother.Count</span>
                            <div class="small">Tehén: @tehenEllesCount | Üsző: @uszoEllesCount</div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="p-2 border rounded bg-light text-center">
                            <small class="text-muted d-block">Ikerellések</small>
                            <span class="h5 mb-0 text-info">@birthsByMother.Count(g => g.Count() > 1)</span>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="p-2 border rounded bg-light text-center border-danger">
                            <small class="text-danger d-block">Hullaellés</small>
                            <span class="h5 mb-0 text-danger">@hullaEllesCount</span>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="p-2 border rounded bg-success-subtle text-center border-success">
                            <small class="text-success d-block">Élő szaporulat</small>
                            <span class="h5 mb-0 text-success">@newborns.Count(n => n.IsAlive)</span>
                            <div class="small text-success">@newborns.Count(n => n.IsAlive && n.Gender == Gender.Bika) B | @newborns.Count(n => n.IsAlive && n.Gender == Gender.Üsző) Ü</div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
    @* --- 2. SZEKCIÓ: KIKERÜLÉSEK (Közös keretben az ENAR kijelentéshez) --- *@
    <div class="card shadow border-0 bg-light p-4 mb-5">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h4 class="mb-0 text-dark"><i class="bi bi-box-arrow-right"></i> Kikerülések kezelése (ENAR 5136)</h4>
            <div class="text-muted small">Válassza ki a bejelenteni kívánt tételeket a listákból!</div>
        </div>

        <form id="enarForm" asp-action="GenerateEnar5136Package" asp-controller="Sales" method="post">
            @* ELHULLÁSOK AL-KÁRTYA *@
            <div class="card shadow-sm mb-4 border-danger">
                <div class="card-header bg-danger text-white d-flex justify-content-between align-items-center">
                    <h6 class="mb-0">Elhullások kijelölése</h6>
                    <div class="form-check">
                        <input class="form-check-input select-all-section" type="checkbox" data-target="death-check" id="selectAllDeaths">
                        <label class="form-check-label small" for="selectAllDeaths">Mind</label>
                    </div>
                </div>
                <div class="card-body p-0">
                <table class="table table-hover mb-0 align-middle">
                    <thead class="table-light">
                        <tr>
                            <th style="width:40px;" class="ps-3"></th>
                            <th>Dátum</th>
                            <th>Fülszám</th>
                            <th>Korcsoport</th>
                            <th>Tenyészet</th>
                            <th class="text-end">Súly (kg)</th>
                            <th class="text-center">Státusz</th>
                            <th class="text-end pe-3">Művelet</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in elhullasok)
                        {
                            <tr class="@(item.IsReported ? "table-light" : "")">
                                <td class="ps-3">
                                    @if (!item.IsReported)
                                    {
                                        <input type="checkbox" name="selectedIds" value="@item.Id" class="form-check-input enar-check death-check border-danger">
                                    }
                                    else
                                    {
                                        <i class="bi bi-cloud-check-fill text-success fs-5"></i>
                                    }
                                </td>
                                <td>@item.SaleDate.ToString("yyyy.MM.dd")</td>
                                <td>
                                    <a asp-controller="Cattles" asp-action="Edit" asp-route-id="@item.CattleId"
                                           asp-route-returnUrl="@Context.Request.Path@Context.Request.QueryString"
                                           class="fw-bold text-decoration-none text-danger">
                                        @item.Cattle?.EarTag
                                    </a>
                                </td>
                                <td>@item.Cattle?.AgeGroup</td>
                                <td><small class="text-muted">@item.Cattle?.CurrentHerd?.HerdCode</small></td>
                                <td class="text-end">@item.GrossWeight.ToString("N1")</td>
                                <td class="text-center">
                                    @if (item.IsReported)
                                    {
                                        <span class="badge bg-success-subtle text-success border border-success">Beküldve</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning-subtle text-warning border border-warning">Várakozik</span>
                                    }
                                </td>
                                <td class="text-end pe-3">
                                    @if (item.IsReported)
                                    {
                                        <button type="button" onclick="undoReport(@item.Id)" class="btn btn-sm btn-outline-warning" title="Visszavonás (újra beküldhető lesz)">
                                            <i class="bi bi-arrow-counterclockwise"></i> Visszavon
                                        </button>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

            @* ÉRTÉKESÍTÉSEK AL-KÁRTYA *@
            <div class="card shadow-sm mb-4 border-success">
                <div class="card-header bg-success text-white d-flex justify-content-between align-items-center">
                    <h6 class="mb-0">Értékesítések kijelölése</h6>
                    <div class="form-check">
                        <input class="form-check-input select-all-section" type="checkbox" data-target="sale-check" id="selectAllSales">
                        <label class="form-check-label small" for="selectAllSales">Mind</label>
                    </div>
                </div>
                <div class="card-body p-0">
                <table class="table table-hover mb-0 align-middle">
                    <thead class="table-light">
                        <tr>
                            <th style="width:40px;" class="ps-3"></th>
                            <th>Dátum</th>
                            <th>Fülszám</th>
                            <th>Vevő</th>
                            <th>Típus</th>
                            <th class="text-end">Végösszeg</th>
                            <th class="text-center">Státusz</th>
                            <th class="text-end pe-3">Művelet</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in ertekesitesek)
                        {
                            <tr class="@(item.IsReported ? "table-light" : "")">
                                <td class="ps-3">
                                    @if (!item.IsReported)
                                    {
                                        <input type="checkbox" name="selectedIds" value="@item.Id" class="form-check-input enar-check sale-check border-success">
                                    }
                                    else
                                    {
                                        <i class="bi bi-cloud-check-fill text-success fs-5"></i>
                                    }
                                </td>
                                <td>@item.SaleDate.ToString("yyyy.MM.dd")</td>
                                <td>
                                    <a asp-controller="Cattles" asp-action="Edit" asp-route-id="@item.CattleId"
                                           asp-route-returnUrl="@Context.Request.Path@Context.Request.QueryString"
                                           class="fw-bold text-decoration-none text-success">
                                        @item.Cattle?.EarTag
                                    </a>
                                </td>
                                <td>@item.Customer?.Name</td>
                                <td><span class="badge bg-light text-dark border small">@item.Type.ToString()</span></td>
                                <td class="text-end fw-bold">@item.TotalNetPrice.ToString("N0") Ft</td>
                                <td class="text-center">
                                    @if (item.IsReported)
                                    {
                                        <span class="badge bg-success-subtle text-success border border-success">Beküldve</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning-subtle text-warning border border-warning">Várakozik</span>
                                    }
                                </td>
                                <td class="text-end pe-3">
                                    @if (item.IsReported)
                                    {
                                        <button type="button" onclick="undoReport(@item.Id)" class="btn btn-sm btn-outline-warning">
                                            <i class="bi bi-arrow-counterclockwise"></i> Visszavon
                                        </button>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
            @* A GOMB MOST MÁR ITT VAN ALUL, A KIJELÖLÉSEK UTÁN *@
            <div class="d-grid gap-2 d-md-flex justify-content-md-end mt-4">
                <div id="checkCounter" class="me-3 align-self-center text-muted fw-bold" style="display:none;">
                    <span id="selectedCount">0</span> tétel kijelölve
                </div>
                <button type="button" onclick="submitEnarPackage()" class="btn btn-success btn-lg shadow" id="btnMainExport" disabled>
                    <i class="bi bi-file-zip-fill"></i> Kijelöltek ENAR kijelentése (ZIP generálása)
                </button>
            </div>
    </form>
    </div>
</div>
@* Rejtett form a visszavonáshoz (Sale visszavonás) *@
<form id="undoSaleForm" asp-action="UndoReport" asp-controller="Sales" method="post" style="display:none;">
    <input type="hidden" name="id" id="undoSaleId" />
</form>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('.select-all-section').click(function () {
                var targetClass = $(this).data('target');
                $('.' + targetClass).prop('checked', this.checked);
                updateMainButton();
            });

            $(document).on('change', '.enar-check', function() {
                updateMainButton();
            });

            function updateMainButton() {
                var checkedCount = $('.enar-check:checked').length;
                $('#btnMainExport').prop('disabled', checkedCount === 0);
                
                if(checkedCount > 0) {
                    $('#selectedCount').text(checkedCount);
                    $('#checkCounter').fadeIn();
                    $('#btnMainExport').html('<i class="bi bi-check-all"></i> ' + checkedCount + ' tétel beküldése (ZIP)');
                } else {
                    $('#checkCounter').hide();
                    $('#btnMainExport').html('<i class="bi bi-file-zip-fill"></i> Kijelöltek ENAR kijelentése');
                }
            }
        });

        function submitEnarPackage() {
            if (confirm('A kijelölt tételekről ENAR csomag készül. Folytatja?')) {
                $('#enarForm').submit();
                setTimeout(function() { location.reload(); }, 2000);
            }
        }
    </script>
}