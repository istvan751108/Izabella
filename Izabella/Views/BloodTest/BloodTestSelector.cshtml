@model IEnumerable<Izabella.Models.Cattle>

<style>
    .my-handle {
        width: 34px;
        height: 34px;
        background-color: #f8f9fa;
        border: 2px solid #0d6efd;
        border-radius: 6px;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: grab !important;
        color: #0d6efd;
    }

        .my-handle:hover {
            background-color: #0d6efd;
            color: white;
        }

    .sortable-ghost {
        opacity: 0.3;
        background-color: #cfe2ff !important;
        border: 2px dashed #0d6efd;
    }
</style>
<style>
    .not-selected {
        opacity: 0.5;
        background-color: #f8f9fa;
    }

        .not-selected .my-handle {
            display: none;
        }
    /* Ami nincs kijelölve, azt ne lehessen rendezni */
</style>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2><i class="bi bi-droplet-half text-danger"></i> Vérvizsgálati lista összeállítása</h2>

        <form method="get" class="d-flex gap-2">
            <select name="ageGroup" class="form-select" onchange="this.form.submit()">
                <option value="">-- Minden korcsoport --</option>
                @foreach (var group in ViewBag.AgeGroups)
                {
                    <option value="@group" selected="@(ViewBag.SelectedAgeGroup == group)">@group</option>
                }
            </select>
            <a asp-action="BloodTestSelector" class="btn btn-outline-secondary">Alaphelyzet</a>
        </form>
    </div>

    <div class="row">
        <div class="col-md-9">
            <form asp-action="SaveBloodTestList" method="post" id="bloodForm">
                <div class="card shadow">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-dark">
                            <tr>
                                <th style="width: 40px;"><input type="checkbox" id="selectAll" class="form-check-input"></th>
                                <th style="width: 50px;"></th>
                                <th style="width: 80px;">Vércső</th>
                                <th>Fülszám</th>
                                <th>Korcsoport</th>
                            </tr>
                        </thead>
                        <tbody id="bloodTestList">
                            @foreach (var item in Model)
                            {
                                <tr class="sortable-row not-selected">
                                    <td>
                                        <input type="checkbox" name="selectedCattleIds" value="@item.Id" class="form-check-input row-checkbox">
                                    </td>
                                    <td>
                                        <div class="my-handle"><i class="bi bi-grip-vertical"></i></div>
                                    </td>
                                    <td class="tube-index fw-bold text-primary">--</td>
                                    <td><strong>@item.EarTag</strong></td>
                                    <td><span class="badge bg-light text-dark">@item.AgeGroup</span></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </form>
        </div>

        <div class="col-md-3">
            <div class="card shadow sticky-top" style="top: 20px;">
                <div class="card-body">
                    <h6>Műveletek</h6>
                    <p class="small text-muted">Húzza a kék ikonokat a sorrend módosításához. A mentés után a rendszer automatikusan kiosztja a csőszámokat.</p>
                    <button type="submit" form="bloodForm" class="btn btn-primary w-100 mb-2">
                        <i class="bi bi-save"></i> Vércsőszám Export
                    </button>
                    <hr />
                    <p class="small">Export tenyésztési adatokkal:</p>
                    <button type="button" onclick="exportBreeding()" class="btn btn-outline-success w-100">
                        <i class="bi bi-file-earmark-excel"></i> Export
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.0/Sortable.min.js"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function() {
        var el = document.getElementById('bloodTestList');
        if (el) {
        new Sortable(el, {
        handle: '.my-handle',
        animation: 200,
        ghostClass: 'sortable-ghost',
        onEnd: updateIndices
        });
        }

        // Checkbox eseménykezelők
        const checkboxes = document.querySelectorAll('.row-checkbox');
        checkboxes.forEach(cb => {
        cb.addEventListener('change', function() {
        const row = this.closest('tr');
        if (this.checked) {
        row.classList.remove('not-selected');
        } else {
        row.classList.add('not-selected');
        }
        updateIndices();
        });
        });

        // Mindet kijelöl gomb
        document.getElementById('selectAll').addEventListener('change', function() {
        checkboxes.forEach(cb => {
        cb.checked = this.checked;
        const row = cb.closest('tr');
        if (this.checked) row.classList.remove('not-selected');
        else row.classList.add('not-selected');
        });
        updateIndices();
        });
        });

        function updateIndices() {
        let index = 1;
        document.querySelectorAll('#bloodTestList tr').forEach(row => {
        const cb = row.querySelector('.row-checkbox');
        const indexCell = row.querySelector('.tube-index');

        if (cb.checked) {
        indexCell.innerText = index.toString().padStart(2, '0');
        index++;
        } else {
        indexCell.innerText = "--";
        }
        });
        }

        // A Breeding exportnál is csak a kijelölteket küldjük el
        function exportBreeding() {
        const params = new URLSearchParams();
        document.querySelectorAll('.row-checkbox:checked').forEach(cb => {
        params.append('ids', cb.value);
        });

        if (params.toString() === "") {
        alert("Kérlek, válassz ki legalább egy állatot!");
        return;
        }

        window.location.href = '@Url.Action("ExportBreedingExcel")?' + params.toString();
        }
    </script>
}