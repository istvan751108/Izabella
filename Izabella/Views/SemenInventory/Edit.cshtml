@model Izabella.Models.BullSemen

@{
    ViewData["Title"] = "Bikasperma szerkesztése";
}

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="display-6 fw-bold text-primary">
                <i class="bi bi-pencil-square"></i> Bikasperma szerkesztése
            </h1>
            <p class="text-muted mb-0">@Model.BullName (@Model.Klsz)</p>
        </div>
    </div>

    <div class="card shadow">
        <div class="card-body">
            <form asp-action="Edit" method="post">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
                <input type="hidden" asp-for="Id" />

                <div class="row g-3">
                    <div class="col-md-3">
                        <label asp-for="Klsz" class="form-label fw-bold"></label>
                        <input asp-for="Klsz" class="form-control" />
                        <span asp-validation-for="Klsz" class="text-danger"></span>
                    </div>

                    <div class="col-md-5">
                        <label asp-for="BullName" class="form-label fw-bold"></label>
                        <input asp-for="BullName" class="form-control" />
                        <span asp-validation-for="BullName" class="text-danger"></span>
                    </div>

                    <div class="col-md-4">
                        <label asp-for="ProductionNumber" class="form-label fw-bold"></label>
                        <input asp-for="ProductionNumber" class="form-control" />
                        <span asp-validation-for="ProductionNumber" class="text-danger"></span>
                    </div>

                    <div class="col-md-3">
                        <label asp-for="StockQuantity" class="form-label fw-bold"></label>
                        <input asp-for="StockQuantity" class="form-control" />
                        <span asp-validation-for="StockQuantity" class="text-danger"></span>
                    </div>

                    <div class="col-md-3">
                        <label asp-for="PurchasePrice" class="form-label"></label>
                        <input asp-for="PurchasePrice"
                               type="number"
                               step="1"
                               value="@(Model.PurchasePrice.HasValue ? Model.PurchasePrice.Value.ToString("F0") : "")"
                               class="form-control" />
                        <span asp-validation-for="PurchasePrice" class="text-danger"></span>
                    </div>

                    <div class="col-md-3">
                        <label asp-for="ContainerId" class="form-label"></label>
                        <input asp-for="ContainerId" class="form-control" />
                        <span asp-validation-for="ContainerId" class="text-danger"></span>
                    </div>

                    <div class="col-md-3">
                        <label asp-for="Breed" class="form-label"></label>
                        <input asp-for="Breed" class="form-control" />
                        <span asp-validation-for="Breed" class="text-danger"></span>
                    </div>

                    <div class="col-md-3">
                        <label asp-for="Origin" class="form-label"></label>
                        <select asp-for="Origin" class="form-select" asp-items="Html.GetEnumSelectList<SemenOrigin>()"></select>
                    </div>

                    <div class="col-md-3">
                        <label asp-for="Type" class="form-label"></label>
                        <select asp-for="Type" class="form-select" asp-items="Html.GetEnumSelectList<SemenType>()"></select>
                    </div>

                    <div class="col-md-3">
                        <label asp-for="ProductionMethod" class="form-label"></label>
                        <select asp-for="ProductionMethod" class="form-select" asp-items="Html.GetEnumSelectList<SemenProductionMethod>()"></select>
                    </div>

                    <div class="col-md-3 d-flex align-items-end">
                        <div class="form-check form-switch mb-2">
                            <input class="form-check-input" asp-for="IsSexed" />
                            <label class="form-check-label" asp-for="IsSexed"></label>
                        </div>
                    </div>

                    <div class="col-md-3 d-flex align-items-end">
                        <div class="form-check form-switch mb-2">
                            <input class="form-check-input" asp-for="IsCycleBull" />
                            <label class="form-check-label" asp-for="IsCycleBull"></label>
                        </div>
                    </div>

                    <div class="col-md-3 d-flex align-items-end">
                        <div class="form-check form-switch mb-2">
                            <input class="form-check-input" asp-for="IsActive" />
                            <label class="form-check-label" asp-for="IsActive"></label>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="SupplierName" class="form-label"></label>
                        <input asp-for="SupplierName" class="form-control" />
                        <span asp-validation-for="SupplierName" class="text-danger"></span>
                    </div>

                    <div class="col-md-3">
                        <label asp-for="FirstUseDate" class="form-label"></label>
                        <input asp-for="FirstUseDate" type="date" class="form-control" />
                        <span asp-validation-for="FirstUseDate" class="text-danger"></span>
                    </div>

                    <div class="col-md-3">
                        <label asp-for="LastUseDate" class="form-label"></label>
                        <input asp-for="LastUseDate" type="date" class="form-control" />
                        <span asp-validation-for="LastUseDate" class="text-danger"></span>
                    </div>
                </div>

                <div class="mt-4 pt-3 border-top d-flex justify-content-between">
                    <a asp-action="Index" class="btn btn-secondary">
                        <i class="bi bi-arrow-left"></i> Vissza
                    </a>

                    <div>
                        <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-info me-2">
                            <i class="bi bi-eye"></i> Adatlap
                        </a>
                        <button type="submit" class="btn btn-primary btn-lg px-5">
                            <i class="bi bi-check-lg"></i> Mentés
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        // Felüldefiniáljuk a szám validációt, hogy ne legyen gond a tizedesekkel
        $.validator.methods.number = function (value, element) {
            return this.optional(element) || !isNaN(parseFloat(value));
        }
    </script>
}