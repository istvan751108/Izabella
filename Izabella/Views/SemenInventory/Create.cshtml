@model Izabella.Models.BullSemen

<h2>@(Model.Klsz != null ? "Bevételezés: " + Model.BullName : "Új sperma rögzítése")</h2>

<div class="card shadow">
    <div class="card-body">
        <form asp-action="@(ViewContext.RouteData.Values["action"].ToString() == "Edit" ? "Edit" : "ProcessRestock")" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Id" />

            <div class="row g-3">
                @* Elsődleges adatok *@
                <div class="col-md-3">
                    <label asp-for="Klsz" class="form-label fw-bold"></label>
                    <input asp-for="Klsz" class="form-control" />
                </div>
                <div class="col-md-5">
                    <label asp-for="BullName" class="form-label fw-bold"></label>
                    <input asp-for="BullName" class="form-control" />
                </div>
                <div class="col-md-4">
                    <label asp-for="ProductionNumber" class="form-label fw-bold"></label>
                    <input asp-for="ProductionNumber" class="form-control text-primary fw-bold" />
                    <span asp-validation-for="ProductionNumber" class="text-danger small"></span>
                </div>

                @* Technikai adatok *@
                <div class="col-md-3">
                    <label asp-for="StockQuantity" class="form-label fw-bold"></label>
                    <input asp-for="StockQuantity" class="form-control border-success" />
                </div>
                <div class="col-md-3">
                    <label asp-for="PurchasePrice" class="form-label"></label>
                    <input asp-for="PurchasePrice" class="form-control" />
                </div>
                <div class="col-md-3">
                    <label asp-for="ContainerId" class="form-label"></label>
                    <input asp-for="ContainerId" class="form-control" />
                </div>
                <div class="col-md-3">
                    <label asp-for="Breed" class="form-label"></label>
                    <input asp-for="Breed" class="form-control" />
                </div>

                <hr />

                @* Kapcsolók és Választók *@
                <div class="col-md-3">
                    <label asp-for="Origin" class="form-label"></label>
                    <select asp-for="Origin" class="form-select" asp-items="Html.GetEnumSelectList<SemenOrigin>()"></select>
                </div>
                <div class="col-md-3">
                    <label asp-for="Type" class="form-label"></label>
                    <select asp-for="Type" class="form-select" asp-items="Html.GetEnumSelectList<SemenType>()"></select>
                </div>
                <div class="col-md-3">
                    <label asp-for="ProductionMethod" class="form-label"></label>
                    <select asp-for="ProductionMethod" class="form-select" asp-items="Html.GetEnumSelectList<SemenProductionMethod>()"></select>
                </div>
                
                <div class="col-md-3 d-flex align-items-end">
                    <div class="form-check form-switch mb-2">
                        <input class="form-check-input" type="checkbox" asp-for="IsSexed">
                        <label class="form-check-label" asp-for="IsSexed">Szexált sperma</label>
                    </div>
                </div>

                <div class="col-md-3">
                    <div class="form-check form-switch">
                        <input class="form-check-input" type="checkbox" asp-for="IsCycleBull">
                        <label class="form-check-label" asp-for="IsCycleBull">Ciklusbika-e</label>
                    </div>
                </div>
                
                <div class="col-md-9">
                    <label asp-for="SupplierName" class="form-label"></label>
                    <input asp-for="SupplierName" class="form-control" />
                </div>
            </div>

            <div class="mt-4 pt-3 border-top d-flex justify-content-between">
                <a asp-action="Index" class="btn btn-secondary">Vissza a listához</a>
                <button type="submit" class="btn btn-primary btn-lg px-5">Mentés</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        // Itt lehetne egy AJAX hívás, ami ellenőrzi, hogy létezik-e a KLSZ+Prod kombináció,
        // és vizuálisan jelzi, hogy "Hozzáadás" vagy "Új felvétel" történik-e.
    </script>
}