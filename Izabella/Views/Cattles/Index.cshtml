@model IEnumerable<Izabella.Models.Cattle>

@{
    ViewData["Title"] = "Állomány nyilvántartás";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="bi bi-card-list"></i> Aktív állomány</h2>
        <div>
            <button type="submit" form="salesForm" class="btn btn-warning fw-bold shadow-sm me-2">
                <i class="bi bi-cart-check"></i> Kijelöltek értékesítése
            </button>
            <a asp-action="Create" class="btn btn-primary"><i class="bi bi-plus-circle"></i> Új állat kézi felvitele</a>
        </div>
    </div>

    <div class="card shadow-sm mb-4 bg-light">
        <div class="card-body">
            <form asp-action="Index" method="get" class="row g-3">
                <div class="col-md-3">
                    <label class="form-label small fw-bold">Keresés fülszámra</label>
                    <input type="text" name="searchTag" class="form-control" placeholder="Pl: L1234..." value="@Context.Request.Query["searchTag"]">
                </div>
                <div class="col-md-3">
                    <label class="form-label small fw-bold">Korcsoport szűrés</label>
                    <select name="searchGroup" class="form-select">
                        <option value="">-- Összes --</option>
                        @if (ViewBag.AgeGroups != null)
                        {
                            foreach (var group in ViewBag.AgeGroups)
                            {
                                <option value="@group">@group</option>
                            }
                        }
                    </select>
                </div>
                <div class="col-md-2 d-flex align-items-end">
                    <button type="submit" class="btn btn-dark w-100">Szűrés</button>
                </div>
                <div class="col-md-2 d-flex align-items-end">
                    <a asp-action="Index" class="btn btn-outline-secondary w-100">Alaphelyzet</a>
                </div>
            </form>
        </div>
    </div>

    <form id="salesForm" asp-controller="Sales" asp-action="Checkout" method="post">
        <div class="table-responsive shadow-sm border rounded bg-white">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-dark">
                    <tr>
                        <th style="width: 40px;">
                            <input type="checkbox" id="selectAll" class="form-check-input" title="Mind kijelöl" />
                        </th>
                        <th>Fülszám</th>
                        <th>ENAR</th>
                        <th>Korcsoport</th>
                        <th>Neme</th>
                        <th>Született</th>
                        <th>Tenyészet</th>
                        <th>Marhalevél</th>
                        <th class="text-center">Műveletek</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                <input type="checkbox" name="selectedCattleIds" value="@item.Id" class="form-check-input cattle-checkbox" />
                            </td>
                            <td class="fw-bold text-primary">@item.EarTag</td>
                            <td class="small">@item.EnarNumber</td>
                            <td>
                                <span class="badge @(item.AgeGroup == "Tehén" ? "bg-success" : "bg-info text-dark")">
                                    @item.AgeGroup
                                </span>
                            </td>
                            <td>@(item.Gender == Gender.Bika ? "♂ Bika" : "♀ Üsző")</td>
                            <td>@item.BirthDate.ToString("yyyy.MM.dd.")</td>
                            <td>@item.CurrentHerd?.Name</td>
                            <td>
                                @if (item.PassportNumber == "Kérve")
                                {
                                    <span class="badge bg-warning text-dark border border-warning shadow-sm">
                                        <i class="bi bi-hourglass-split"></i> Kérve
                                    </span>
                                }
                                else if (item.PassportNumber == "Nincs")
                                {
                                    <span class="badge bg-secondary-subtle text-secondary border">Nincs</span>
                                }
                                else
                                {
                                    <span class="text-dark fw-bold small">@item.PassportNumber</span>
                                }
                            </td>
                            <td class="text-end" style="min-width: 320px;">
                                <div class="btn-group shadow-sm" role="group">
                                    @if (item.PassportNumber == "Kérve")
                                    {
                                        @* Gomb, ami nem form, de meghív egy mini javascriptet *@
                                        <button type="button" class="btn btn-outline-warning btn-sm border-end-0"
                                                onclick="submitUndo('@item.Id')">
                                            <i class="bi bi-arrow-counterclockwise"></i> Visszavon
                                        </button>
                                    }
        
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-primary btn-sm">
                                        <i class="bi bi-pencil"></i> Szerkeszt
                                    </a>
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-info btn-sm text-white">
                                        <i class="bi bi-eye"></i> Adatlap
                                    </a>
                                    <a asp-controller="Cattle" asp-action="RecordDeath" asp-route-id="@item.Id" class="btn btn-danger btn-sm">
                                        <i class="bi bi-x-circle"></i> Elhullás
                                    </a>
                                </div>
    
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-light text-danger ms-2 border" title="Törlés">
                                    <i class="bi bi-trash"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </form>
    <form id="globalUndoBirthForm" asp-action="UndoBirthReport" method="post" style="display:none;">
        @Html.AntiForgeryToken()
        <input type="hidden" name="id" id="undoBirthId" />
    </form>
</div>

@section Scripts {
    <script>
        // Mind kijelölése funkció
        document.getElementById('selectAll').onclick = function() {
            var checkboxes = document.getElementsByClassName('cattle-checkbox');
            for (var checkbox of checkboxes) {
                checkbox.checked = this.checked;
            }
        }

        // Ellenőrzés elküldés előtt
        document.getElementById('salesForm').onsubmit = function(e) {
            // Javítva: .length (kis l betűvel)
            var checkedCount = document.querySelectorAll('.cattle-checkbox:checked').length;
            if (checkedCount === 0) {
                alert('Kérlek, válassz ki legalább egy állatot az értékesítéshez!');
                e.preventDefault();
                return false;
            }
        };

        // A visszavonásért felelős függvény - most már a script tagen belül
        function submitUndo(id) {
            if (confirm('Biztosan visszavonja a bejelentést?')) {
                var input = document.getElementById('undoBirthId');
                var form = document.getElementById('globalUndoBirthForm');
                if (input && form) {
                    input.value = id;
                    form.submit();
                } else {
                    alert('Hiba: A visszavonási űrlap nem található az oldalon.');
                }
            }
        }
    </script>
}