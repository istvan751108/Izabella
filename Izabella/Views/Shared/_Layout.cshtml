<!DOCTYPE html>
<html lang="hu">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Izabella</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <style>
        body { padding-top: 70px; background-color: #f4f7f6; }
        .navbar { background-color: #2c3e50 !important; }
        .nav-link { font-weight: 500; color: white !important; margin-right: 15px; }
        .nav-link:hover { color: #3498db !important; }
        .dropdown-menu { background-color: #2c3e50; border: 1px solid #34495e; }
        .dropdown-item { color: white; }
        .dropdown-item:hover { background-color: #3498db; color: white; }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark fixed-top">
        <div class="container">
            <a class="navbar-brand font-weight-bold" asp-controller="Home" asp-action="Index">IZABELLA DB</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainMenu">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="mainMenu">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Home" asp-action="Index">Főoldal</a>
                    </li>

                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" id="cattleDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                            Állomány kezelés
                        </a>
                        <ul class="dropdown-menu shadow dropdown-menu-dark" aria-labelledby="cattleDropdown">
                            <li><a class="dropdown-item" asp-controller="Cattle" asp-action="Calving">Új ellés rögzítése</a></li>
                            <li><a class="dropdown-item" asp-controller="Cattle" asp-action="GenderChangeList">Borjú nemének megváltoztatása</a></li>
                            <li><a class="dropdown-item" asp-controller="Cattles" asp-action="Index">Aktív Állomány listája</a></li>
                            <li><a class="dropdown-item" asp-controller="Cattle" asp-action="PassportUpdate">Marhalevél szám feltöltés</a></li>
                            <li><a class="dropdown-item" asp-controller="Sales" asp-action="Index">Kikerülési napló</a></li>
                            <li><a class="dropdown-item" asp-controller="Cattles" asp-action="Movement">Állománymozgatás és Súlymérés</a></li>
                            <li><a class="dropdown-item" asp-controller="Sales" asp-action="MonthlyReport">ENAR ügyintézés</a></li>
                            <li><hr class="dropdown-divider"></li>
                          
                            <li><a class="dropdown-item text-danger" asp-controller="Cattle" asp-action="DeathLogList">Elhullások naplója</a></li>
                        </ul>
                    </li>

                    @if (User.Identity.IsAuthenticated)
                    {
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" id="manureDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                Trágyakezelés
                            </a>
                            <ul class="dropdown-menu shadow dropdown-menu-dark" aria-labelledby="manureDropdown">
                                @if (User.IsInRole("Admin"))
                                {
                                    <li><a class="dropdown-item" asp-controller="Manure" asp-action="Index">Trágya rögzítés</a></li>
                                    <li><hr class="dropdown-divider"></li>
                                }
                                <li><a class="dropdown-item" asp-controller="Report" asp-action="Index">Havi riport (Táblázatok)</a></li>
                                <li><a class="dropdown-item" asp-controller="Report" asp-action="Charts">Grafikonok & Statisztika</a></li>
                            </ul>
                        </li>
                    }
                    @if (User.IsInRole("Admin"))
                    {
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle text-warning" href="#" id="adminDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                <i class="bi bi-gear-fill"></i> Adminisztráció
                            </a>
                            <ul class="dropdown-menu shadow dropdown-menu-dark" aria-labelledby="adminDropdown">
                                <li><a class="dropdown-item" asp-controller="Companies" asp-action="Index">Cégek kezelése</a></li>
                                <li><a class="dropdown-item" asp-controller="Herds" asp-action="Index">Tenyészetek kezelése</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item" asp-controller="DeathReasons" asp-action="Index">Elhullás okok kezelése</a></li>
                                <li><a class="dropdown-item" asp-controller="Customers" asp-action="Index">Vásárlók kezelése</a></li>
                                <li><a class="dropdown-item" asp-controller="Admin" asp-action="Users">Felhasználók kezelése</a></li>
                            </ul>
                        </li>
                    }
                </ul>

                @* Itt jelenik meg a Bejelentkezés/Kijelentkezés *@
                <div class="navbar-nav">
                    <partial name="_LoginPartial" />
                </div>
            </div>
        </div>
    </nav>

    <div class="container mt-4">
        @RenderBody()
        
        @* Toast értesítések *@
        <div class="toast-container position-fixed bottom-0 end-0 p-3">
            <div id="liveToast" class="toast align-items-center text-white bg-success border-0" role="alert" aria-live="assertive" aria-atomic="true">
                <div class="d-flex">
                    <div class="toast-body" id="toastMessage">Sikeres mentés!</div>
                    <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
                </div>
            </div>
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/gh/linways/table-to-excel@v1.0.4/dist/tableToExcel.js"></script>

    <script>
        function showToast(message, isError = false) {
        const toastElement = document.getElementById('liveToast');
        const toastMessage = document.getElementById('toastMessage');
        if (!toastElement) return;

        // Szín beállítása
        toastElement.classList.remove('bg-success', 'bg-danger');
        toastElement.classList.add(isError ? 'bg-danger' : 'bg-success');

        toastMessage.innerText = message;

        // Autohide beállítása (5000ms = 5 másodperc)
        const toast = new bootstrap.Toast(toastElement, { delay: 5000, autohide: true });
        toast.show();
        }
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>