@model IEnumerable<Izabella.Models.MatingSuggestion>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1><i class="bi bi-diagram-3 text-success"></i> Párosítási Terv</h1>
    </div>

    <div class="card shadow-sm mb-4 border-success">
        <div class="card-body">
            <h5 class="card-title">Javaslat hozzáadása</h5>
            <form asp-action="Create" method="post" class="row g-3 align-items-end">
                <div class="col-md-3">
                    <label class="form-label small fw-bold">Tehén fülszáma</label>
                    <input name="CattleEarTag" class="form-control" required placeholder="HU 123..." />
                </div>
                <div class="col-md-3">
                    <label class="form-label small fw-bold">Bika KLSZ</label>
                    <input name="SuggestedKlsz" class="form-control" required placeholder="34567" />
                </div>
                <div class="col-md-2">
                    <label class="form-label small fw-bold">Prioritás</label>
                    <select name="Priority" class="form-select">
                        <option value="1">1 (Elsődleges)</option>
                        <option value="2">2 (Tartalék)</option>
                        <option value="3">3 (Egyéb)</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-success w-100">Mentés</button>
                </div>
            </form>
        </div>
    </div>

    <div class="card shadow-sm">
        <table class="table table-hover mb-0">
            <thead class="table-dark">
                <tr>
                    <th>Tehén</th>
                    <th>Javasolt Bika (KLSZ)</th>
                    <th>Prioritás</th>
                    <th>Rögzítve</th>
                    <th class="text-end">Művelet</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var group in Model.GroupBy(x => x.CattleEarTag))
                {
                    bool firstRow = true;
                    foreach (var item in group)
                    {
                        <tr>
                            <td>@(firstRow ? item.CattleEarTag : "")</td>
                            <td>
                                <span class="fw-bold">@item.SuggestedBullName</span>
                                <small class="text-muted">(@item.SuggestedKlsz)</small>
                            </td>
                            <td>
                                <span class="badge @(item.Priority == 1 ? "bg-primary" : "bg-secondary")">
                                    @item.Priority. helyen
                                </span>
                            </td>
                            <td>@item.CreatedDate.ToShortDateString()</td>
                            <td class="text-end">
                                <form asp-action="Delete" asp-route-id="@item.Id" method="post">
                                    <button type="submit" class="btn btn-sm text-danger" onclick="return confirm('Törlöd?')">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                        firstRow = false;
                    }
                }
            </tbody>
        </table>
    </div>
</div>